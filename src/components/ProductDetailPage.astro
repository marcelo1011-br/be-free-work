---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import TourCard from "./TourCard.astro";
import Breadcrumbs from "./Breadcrumbs.astro";
import BookingModal from "./BookingModal.astro";
import { useTranslations } from "../i18n/utils";

const {
  item,
  type,
  lang,
  allItems,
  heroImage,
  paymentPolicy,
  cancellationPolicy,
  seoData,
  pageSchemas,
  ogTags,
} = Astro.props;

const t = useTranslations(lang);

const routeMaps = {
  tour: {
    en: "private-tours",
    es: "tours-privados",
    "pt-br": "passeios-privados",
  },
  experience: {
    en: "experiences",
    es: "experiencias",
    "pt-br": "experiencias",
  },
};

const section = type === "experience" ? "experiences" : "tours";
const baseRoute = routeMaps[type]?.[lang] || routeMaps.tour.en;
const relatedItems = allItems
  .filter((candidate) => candidate.category === item.category && candidate.id !== item.id)
  .slice(0, 3);
const tips = item.tips || [];
const faqs = item.faqs || [];
const isCustomItem = item.isCustom || item.pricing?.custom;
const customPriceText = item.pricing?.displayText || "Custom quote";
const contactRoutes = {
  en: "contact",
  es: "contacto",
  "pt-br": "contato",
};
const contactRoute = contactRoutes[lang] || contactRoutes.en;
const alternateRoute = type === "experience" ? routeMaps.tour[lang] : routeMaps.experience[lang];
const overviewTitle = type === "experience" ? t("product.aboutExperience") : t("product.aboutTour");
const overviewIntro = type === "experience" ? t("product.overviewIntroExperience") : t("product.overviewIntroTour");
const alternateLabel = type === "experience" ? t("product.altLineExperienceLabel") : t("product.altLineTourLabel");
const alternateButton = type === "experience" ? t("product.altLineExperienceButton") : t("product.altLineTourButton");

function getFromPrice(pricing = {}) {
  if (pricing.custom) return null;
  if (pricing.from) return pricing.from;
  if (pricing.perPerson) return pricing.perPerson;
  if (pricing.standard) {
    const prices = Object.values(pricing.standard);
    return Math.min(...prices);
  }
  return null;
}

const fromPrice = getFromPrice(item.pricing || {});

const copyByType = {
  tour: {
    en: {
      bookThisItem: "Reserve — Pay Nothing Until 72h Before",
      viewAllItems: "View All Tours",
      whatsappText: "Questions? WhatsApp us",
    },
    es: {
      bookThisItem: "Reservar — Sin Pagar Hasta 72h Antes",
      viewAllItems: "Ver Todos los Tours",
      whatsappText: "¿Dudas? Escríbenos por WhatsApp",
    },
    "pt-br": {
      bookThisItem: "Reserve — Pague Só 72h Antes",
      viewAllItems: "Ver Todos os Passeios",
      whatsappText: "Dúvidas? Fale pelo WhatsApp",
    },
  },
  experience: {
    en: {
      bookThisItem: "Reserve — Pay Nothing Until 72h Before",
      viewAllItems: "View All Experiences",
      whatsappText: "Questions? WhatsApp us",
    },
    es: {
      bookThisItem: "Reservar — Sin Pagar Hasta 72h Antes",
      viewAllItems: "Ver Todas las Experiencias",
      whatsappText: "¿Dudas? Escríbenos por WhatsApp",
    },
    "pt-br": {
      bookThisItem: "Reserve — Pague Só 72h Antes",
      viewAllItems: "Ver Todas as Experiências",
      whatsappText: "Dúvidas? Fale pelo WhatsApp",
    },
  },
};

const waMessages = {
  en: `Hi, I have a question about the ${item.title} tour.`,
  es: `Hola, tengo una pregunta sobre el tour ${item.title}.`,
  "pt-br": `Olá, tenho uma dúvida sobre o passeio ${item.title}.`,
};
const waLink = `https://wa.me/5521979271637?text=${encodeURIComponent(waMessages[lang] || waMessages.en)}`;

const copy = copyByType[type]?.[lang] || copyByType.tour.en;
const breadcrumbItems = [
  { name: "Home", url: `/${lang}` },
  {
    name: type === "experience" ? t("nav.experiences") : t("nav.privateTours"),
    url: `/${lang}/${baseRoute}`,
  },
  { name: item.title, url: `/${lang}/${baseRoute}/${item.slug}` },
];
---

<BaseLayout
  title={seoData.title}
  description={seoData.description}
  image={seoData.image}
  type="product"
  schema={pageSchemas}
  ogTags={ogTags}
>
  <Breadcrumbs items={breadcrumbItems} />

  <section class="product-hero">
    <div class="hero-image">
      <Image
        src={heroImage}
        alt={`${item.title} - ${t("product.heroImageAlt")} ${item.highlights[0]}`}
        width={1920}
        height={1080}
        format="webp"
        quality={85}
        loading="eager"
      />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <div class="container">
        <div class="hero-text">
          <h1 class="hero-title">{item.title}</h1>
          <div class="hero-meta">
            <div class="meta-item">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"></path>
              </svg>
              <span>{item.duration}</span>
            </div>
            {
              fromPrice ? (
                <div class="meta-item hero-price">
                  <span class="price-label">{t("product.from")}</span>
                  <span class="price-value">US$ {fromPrice}</span>
                </div>
              ) : isCustomItem && (
                <div class="meta-item hero-price">
                  <span class="price-custom">{customPriceText}</span>
                </div>
              )
            }
          </div>
          <button type="button" class="btn btn-primary btn-lg" data-booking-trigger>
            {item.ctaText || copy.bookThisItem}
          </button>
        </div>
      </div>
    </div>
  </section>

  <section class="product-overview">
    <div class="container">
      <h2 class="section-title">{overviewTitle}</h2>
      <p class="overview-intro">{overviewIntro}</p>
      {item.fullDescription.split("\n\n").map((paragraph) => (
        <p class="overview-text">{paragraph}</p>
      ))}
      <div class="product-cross-link">
        <p class="cross-link-text">{alternateLabel}</p>
        <a href={`/${lang}/${alternateRoute}`} class="btn btn-outline-secondary btn-md">
          {alternateButton}
        </a>
      </div>
    </div>
  </section>

  <section class="product-details">
    <div class="container">
      <div class="accordion">
        <div class="accordion-item">
          <button class="accordion-header" data-accordion-trigger>
            <div class="accordion-title">
              <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
              </svg>
              <span>{t("product.highlights")}</span>
            </div>
            <svg class="accordion-icon" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
              <path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"></path>
            </svg>
          </button>
          <div class="accordion-content">
            <ul class="highlights-list">
              {item.highlights.map((highlight) => (
                <li class="highlight-item">
                  <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" />
                  </svg>
                  <span>{highlight}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" data-accordion-trigger>
            <div class="accordion-title">
              <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14z"></path>
              </svg>
              <span>{t("product.whatsIncluded")}</span>
            </div>
            <svg class="accordion-icon" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
              <path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"></path>
            </svg>
          </button>
          <div class="accordion-content">
            <div class="included-grid">
              <div class="included-column">
                <h4 class="included-title included-yes">✓ {t("product.included")}</h4>
                <ul class="included-list">
                  {item.included.map((includedItem) => (
                    <li class="included-item">
                      <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" />
                      </svg>
                      <span>{includedItem}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="included-column">
                <h4 class="included-title included-no">✕ {t("product.notIncluded")}</h4>
                <ul class="included-list">
                  {item.notIncluded.map((excludedItem) => (
                    <li class="included-item not-included">
                      <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z" />
                      </svg>
                      <span>{excludedItem}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" data-accordion-trigger>
            <div class="accordion-title">
              <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.31-8.86c-1.77-.45-2.34-.94-2.34-1.67 0-.84.79-1.43 2.1-1.43 1.38 0 1.9.66 1.94 1.64h1.71c-.05-1.34-.87-2.57-2.49-2.97V5H10.9v1.69c-1.51.32-2.72 1.3-2.72 2.81 0 1.79 1.49 2.69 3.66 3.21 1.95.46 2.34 1.15 2.34 1.87 0 .53-.39 1.39-2.1 1.39-1.6 0-2.23-.72-2.32-1.64H8.04c.1 1.7 1.36 2.66 2.86 2.97V19h2.34v-1.67c1.52-.29 2.72-1.16 2.73-2.77-.01-2.2-1.9-2.96-3.66-3.42z"></path>
              </svg>
              <span>{t("product.pricingPayment")}</span>
            </div>
            <svg class="accordion-icon" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
              <path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"></path>
            </svg>
          </button>
          <div class="accordion-content">
            <div class="pricing-content">
              {
                item.pricing?.custom && (
                  <div class="pricing-custom">
                    <div class="price-highlight">
                      <span class="price-custom-title">{customPriceText}</span>
                      <p class="price-custom-description">{t("product.customPriceDescription")}</p>
                      <a href={`/${lang}/${contactRoute}`} class="btn btn-primary">
                        {t("product.customPriceBtn")}
                      </a>
                    </div>
                  </div>
                )
              }

              {
                item.pricing?.priceTable && (
                  <div class="pricing-table-wrapper">
                    <h4>{t("product.standardPackage")}</h4>
                    <table class="pricing-table">
                      <thead>
                        <tr>
                          <th>{t("product.groupSize")}</th>
                          <th>{t("product.price")}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {Object.entries(item.pricing.priceTable).map(([size, price]) => (
                          <tr>
                            <td>{size} {t("product.people")}</td>
                            <td>US$ {price}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )
              }

              {
                item.pricing?.perPerson && (
                  <div class="pricing-table-wrapper">
                    <h4>{t("product.standardPackage")}</h4>
                    <table class="pricing-table">
                      <thead>
                        <tr>
                          <th>{t("product.groupSize")}</th>
                          <th>{t("product.price")}</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr>
                          <td>{t("product.perPerson")}</td>
                          <td>US$ {item.pricing.perPerson}</td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                )
              }

              {
                item.pricing?.standard && (
                  <div class="pricing-table-wrapper">
                    <h4>{t("product.standardPackage")}</h4>
                    <table class="pricing-table">
                      <thead>
                        <tr>
                          <th>{t("product.groupSize")}</th>
                          <th>{t("product.price")}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {Object.entries(item.pricing.standard).map(([size, price]) => (
                          <tr>
                            <td>{size} {t("product.people")}</td>
                            <td>US$ {price}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>

                    {
                      item.pricing.lopesMendes && (
                        <>
                          <h4 style="margin-top: 1.5rem;">
                            {t("product.premiumPackage")} {t("product.lopesMendesPackage")}
                          </h4>
                          <table class="pricing-table">
                            <thead>
                              <tr>
                                <th>{t("product.groupSize")}</th>
                                <th>{t("product.price")}</th>
                              </tr>
                            </thead>
                            <tbody>
                              {Object.entries(item.pricing.lopesMendes).map(([size, price]) => (
                                <tr>
                                  <td>{size} {t("product.people")}</td>
                                  <td>US$ {price}</td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </>
                      )
                    }
                  </div>
                )
              }
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" data-accordion-trigger>
            <div class="accordion-title">
              <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"></path>
              </svg>
              <span>{paymentPolicy.title}</span>
            </div>
            <svg class="accordion-icon" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
              <path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"></path>
            </svg>
          </button>
          <div class="accordion-content">
            <div class="payment-policies">
              <ul class="policy-list">
                {paymentPolicy.items.map((policyItem) => (
                  <li>
                    <strong>{policyItem.label}</strong>
                    {policyItem.text}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" data-accordion-trigger>
            <div class="accordion-title">
              <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"></path>
              </svg>
              <span>{cancellationPolicy.title}</span>
            </div>
            <svg class="accordion-icon" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
              <path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"></path>
            </svg>
          </button>
          <div class="accordion-content">
            <div class="payment-policies">
              <ul class="policy-list">
                {cancellationPolicy.items.map((policyItem) => (
                  <li>
                    <strong>{policyItem.label}</strong>
                    {policyItem.text}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" data-accordion-trigger>
            <div class="accordion-title">
              <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11 7h2v2h-2V7zm0 4h2v6h-2v-6zm1-9C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"></path>
              </svg>
              <span>{t("product.goodToKnow")}</span>
            </div>
            <svg class="accordion-icon" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
              <path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"></path>
            </svg>
          </button>
          <div class="accordion-content">
            <ul class="tips-list">
              {tips.map((tip) => (
                <li class="tip-item">
                  <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" />
                  </svg>
                  <span>{tip}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" data-accordion-trigger>
            <div class="accordion-title">
              <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"></path>
              </svg>
              <span>{t("product.faqs")}</span>
            </div>
            <svg class="accordion-icon" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
              <path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"></path>
            </svg>
          </button>
          <div class="accordion-content">
            <div class="faq-list">
              {faqs.map((faq) => (
                <div class="faq-item">
                  <h4 class="faq-question">{faq.q}</h4>
                  <p class="faq-answer">{faq.a}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {
    relatedItems.length > 0 && (
      <section class="related-products">
        <div class="container">
          <h2 class="section-title">{t("product.relatedItems")}</h2>
          <div class="related-grid grid grid-4">
            {relatedItems.map((relatedItem) => (
              <TourCard item={relatedItem} lang={lang} section={section} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="product-cta">
    <div class="container">
      <div class="cta-content">
        <h2 class="cta-title">{t("product.readyToBook")}</h2>
        <p class="cta-subtitle">{t("product.readyToBookSubtitle")}</p>
        <div class="cta-buttons">
          <button type="button" class="btn btn-primary btn-lg" data-booking-trigger>
            {item.ctaText || copy.bookThisItem}
          </button>
          <a href={`/${lang}/${baseRoute}`} class="btn btn-outline-secondary btn-lg">
            {copy.viewAllItems}
          </a>
        </div>
        <a
          href={waLink}
          class="product-cta__whatsapp"
          target="_blank"
          rel="noopener noreferrer"
        >
          {copy.whatsappText}
        </a>
      </div>
    </div>
  </section>

  <BookingModal tour={item} lang={lang} />
</BaseLayout>

<style>
  .section-title {
    font-size: var(--font-size-h3);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-lg);
  }

  .overview-intro {
    max-width: clamp(42rem, 85vw, 52rem);
    margin: 0 0 var(--space-lg);
    font-size: var(--font-size-h6);
    color: var(--color-text-light);
    line-height: var(--line-height-relaxed);
  }

  .product-cross-link {
    margin-top: var(--space-xl);
    padding: var(--space-lg);
    border: var(--border-width-hairline) solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-soft);
  }

  .cross-link-text {
    margin: 0 0 var(--space-md);
    color: var(--color-text);
    font-weight: var(--font-weight-medium);
  }

  .product-hero {
    --product-hero-overlay-start: color-mix(in srgb, black 70%, transparent);
    --product-hero-overlay-mid: color-mix(in srgb, black 30%, transparent);
    --product-hero-text-shadow: 0 2px 10px color-mix(in srgb, black 50%, transparent);
    --product-hero-price-shadow: 0 2px 8px color-mix(in srgb, black 80%, transparent),
      0 4px 16px color-mix(in srgb, black 60%, transparent);
    --product-hero-max: clamp(40rem, 75vw, 50rem);
    --product-hero-price-opacity: 0.9;
    --accordion-max: clamp(50rem, 85vw, 56.25rem);
    --accordion-border: var(--border-width-regular);
    --accordion-transition: var(--transition-duration-normal) var(--transition-easing-default);
    --accordion-max-height: 3000px;
    --included-grid-min: 280px;
    --spacing-tiny: var(--space-2xs);
    --cta-max: clamp(34rem, 70vw, 43.75rem);
    --cta-subtitle-color: color-mix(in srgb, white 90%, transparent);

    position: relative;
    min-height: 50svh;
    display: flex;
    align-items: flex-end;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .hero-overlay {
    position: absolute;
