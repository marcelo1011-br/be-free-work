---



import TourCard from "./TourCard.astro";
import { tours } from "../data/tours.js";
import { useTranslations } from "../i18n/utils";
import { homeContent } from "../data/homeContent.js";

const { lang } = Astro.props;
const t = useTranslations(lang);


const featuredTours = tours[lang].filter((tour) => tour.isFeatured);


const content = (homeContent[lang] ?? homeContent.en).howItWorks;

const toursBase = `/${lang}/${lang === "en" ? "private-tours" : lang === "es" ? "tours-privados" : "passeios-privados"}`;

const quickFilters = {
  en: [
    { label: "All Tours",     href: toursBase },
    { label: "City Tours",    href: `${toursBase}?category=city-tours` },
    { label: "Day Trips",     href: `${toursBase}?category=day-trips` },
    { label: "Walking Tours", href: `${toursBase}?category=walking-tours` },
  ],
  es: [
    { label: "Todos los Tours",      href: toursBase },
    { label: "Tours por la Ciudad",  href: `${toursBase}?category=city-tours` },
    { label: "Excursiones de Día",   href: `${toursBase}?category=day-trips` },
    { label: "Tours a Pie",          href: `${toursBase}?category=walking-tours` },
  ],
  "pt-br": [
    { label: "Todos os Passeios",       href: toursBase },
    { label: "City Tours",              href: `${toursBase}?category=city-tours` },
    { label: "Passeios de Dia Inteiro", href: `${toursBase}?category=day-trips` },
    { label: "Walking Tours",           href: `${toursBase}?category=walking-tours` },
  ],
};

const filters = quickFilters[lang] ?? quickFilters.en;


const tourBadgeMap = {
  en: {
    "The Essential Rio: Icons, Culture & Hidden Gems": "Most Popular",
    "Rio Express: Christ & Sugarloaf in 5 Hours": "Best for Cruise Passengers",
    "Island Escape: Ilha Grande by Private Speedboat": "Private Speedboat",
    "Your Rio, Your Way: Custom Private Tour": "Fully Customizable"
  },
  es: {
    "El Río Esencial: Íconos, Cultura y Joyas Ocultas": "Más Popular",
    "Río Express: Cristo y Pan de Azúcar en 5 Horas": "Ideal para Cruceristas",
    "Escape a la Isla: Ilha Grande en Lancha Privada": "Lancha Privada",
    "Tu Río, a Tu Manera: Tour Privado Personalizado": "Totalmente Personalizable"
  },
  "pt-br": {
    "O Essencial do Rio: Ícones, Cultura e Joias Escondidas": "Mais Popular",
    "Rio Express: Cristo e Pão de Açúcar em 5 Horas": "Ideal para Cruzeiros",
    "Escapada para a Ilha: Ilha Grande de Lancha Privativa": "Lancha Privada",
    "Seu Rio, do Seu Jeito: Passeio Privado Personalizado": "Totalmente Personalizável"
  }
};
---


<section class="how-it-works">
  <div class="container">
    <h2 class="section-title-decorated">{content.title}</h2>
    
    <div class="steps-grid">
      {content.steps.map((step, index) => (
        <div class="step-card">
          <div class="step-number">{index + 1}</div>
          <div class="step-content">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
          </div>
          {index < content.steps.length - 1 && (
            <div class="step-connector">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>


<section class="featured-tours">
  <div class="container">
    <h2 class="section-title-decorated">{t("featuredTours.title")}</h2>
    <p class="section-subtitle">{t("featuredTours.subtitle")}</p>

    <div class="tours-grid grid grid-3">
      {featuredTours.map((tour) => (
        <TourCard
          tour={tour}
          lang={lang}
          badge={tourBadgeMap[lang]?.[tour.id]}
        />
      ))}
    </div>

    <nav class="quick-filters" aria-label={lang === "en" ? "Browse by category" : lang === "es" ? "Filtrar por categoría" : "Filtrar por categoria"}>
      {filters.map((f, i) => (
        <span class="qf-item">
          {i > 0 && <span class="qf-sep" aria-hidden="true">·</span>}
          <a href={f.href} class="qf-link">{f.label}</a>
        </span>
      ))}
    </nav>

    <div class="section-cta">
      <a
        href={toursBase}
        class="btn btn-outline-primary btn-lg"
      >
        {t("featuredTours.viewAll")}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  
  .how-it-works {
    --step-grid-min: 280px;
    --step-card-lift: -4px;
    --step-number-size: clamp(3rem, 6vw, 3.5rem);
    --step-number-border: var(--border-width-strong);
    --step-connector-offset: -32px;
    --step-icon-size: clamp(2rem, 4vw, 2.25rem);
    --section-subtitle-max: clamp(40rem, 75vw, 50rem);
    --cta-btn-gap: var(--space-xs);

    padding: var(--space-3xl) 0;
    background-color: var(--color-bg-white);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, var(--step-grid-min)), 1fr));
    gap: var(--space-md);
    margin-top: var(--space-2xl);
  }

  .step-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-xl);
    background: none;
    border: none;
    box-shadow: none;
    border-radius: clamp(0.3rem, 0.6vw, 0.375rem);
    transition: transform var(--transition-duration-slow) var(--transition-easing-default);
  }

  .step-card:hover {
    transform: translateY(var(--step-card-lift));
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--step-number-size);
    height: var(--step-number-size);
    border: var(--step-number-border) solid var(--color-border);
    border-radius: 50%;
    font-size: var(--font-size-h4);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .step-content {
    flex-grow: 1;
  }

  .step-title {
    font-size: var(--font-size-h5);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .step-description {
    font-size: var(--font-size-small);
    color: var(--color-text-light);
    line-height: var(--line-height-relaxed);
  }

  .step-connector {
    display: none;
    position: absolute;
    right: var(--step-connector-offset);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-border);
  }

  @media (min-width: 900px) {
    .step-connector {
      display: block;
    }
  }

  
  .featured-tours {
    padding: var(--space-3xl) 0;
    background-color: var(--color-bg-soft);
  }

  .featured-tours .container {
    max-width: none;
    padding-inline: var(--space-xl-compact);
  }

  .section-subtitle {
    text-align: center;
    font-size: var(--font-size-h5);
    color: var(--color-text-light);
    line-height: var(--line-height-relaxed);
    max-width: var(--section-subtitle-max);
    margin: var(--space-md) auto var(--space-2xl);
  }

  .tours-grid {
    margin-bottom: var(--space-md);
    gap: var(--space-md);
  }

  .quick-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    margin-bottom: var(--space-xl);
  }

  .qf-item {
    display: flex;
    align-items: center;
  }

  .qf-sep {
    color: var(--color-border);
    padding: 0 var(--space-2xs);
    user-select: none;
  }

  .qf-link {
    font-size: var(--font-size-small);
    color: var(--color-text-light);
    text-decoration: none;
    padding: var(--space-2xs) var(--space-sm);
    border-radius: clamp(0.25rem, 0.5vw, 0.375rem);
    transition: color var(--transition-duration-slow) var(--transition-easing-default);
  }

  .qf-link:hover {
    color: var(--color-text);
    text-decoration: underline;
  }

  .section-cta {
    text-align: center;
  }

  .section-cta .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--cta-btn-gap);
  }

  .featured-tours .section-cta .btn-outline-primary {
    border-color: transparent;
  }

  .featured-tours .section-cta .btn-outline-primary:focus,
  .featured-tours .section-cta .btn-outline-primary:focus-visible {
    outline: none;
    box-shadow: none;
  }

  
  @media (max-width: 768px) {
    .how-it-works,
    .featured-tours {
      padding: var(--space-2xl) 0;
    }

    .section-title-decorated {
      text-align: center;
    }

    .steps-grid {
      margin-top: var(--space-lg);
      gap: var(--space-md);
    }

    .step-card {
      padding: var(--space-md);
      text-align: center;
      align-items: center;
    }

    .step-number {
      margin-bottom: var(--space-sm);
    }

    .step-title {
      font-size: var(--font-size-body);
    }

    .step-description {
      font-size: var(--font-size-small);
    }


    .section-subtitle {
      margin-bottom: var(--space-xl);
      font-size: var(--font-size-body);
      padding-inline: var(--space-md);
    }

    .tours-grid {
      margin-bottom: var(--space-sm);
    }

    .quick-filters {
      margin-bottom: var(--space-lg);
    }
  }
</style>
