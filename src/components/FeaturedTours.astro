---



import TourCard from "./TourCard.astro";
import { tours } from "../data/tours.js";
import { useTranslations } from "../i18n/utils";
const { lang } = Astro.props;
const t = useTranslations(lang);


const featuredTours = tours[lang].filter((tour) => tour.isFeatured);

const toursBase = `/${lang}/${lang === "en" ? "private-tours" : lang === "es" ? "tours-privados" : "passeios-privados"}`;

const quickFilters = {
  en: [
    { label: "All Tours",     href: toursBase },
    { label: "City Tours",    href: `${toursBase}?category=city-tours` },
    { label: "Day Trips",     href: `${toursBase}?category=day-trips` },
  ],
  es: [
    { label: "Todos los Tours",      href: toursBase },
    { label: "Tours por la Ciudad",  href: `${toursBase}?category=city-tours` },
    { label: "Excursiones de Día",   href: `${toursBase}?category=day-trips` },
  ],
  "pt-br": [
    { label: "Todos os Passeios",       href: toursBase },
    { label: "City Tours",              href: `${toursBase}?category=city-tours` },
    { label: "Passeios de Dia Inteiro", href: `${toursBase}?category=day-trips` },
  ],
};

const filters = quickFilters[lang] ?? quickFilters.en;


const tourBadgeMap = {
  en: {
    "The Essential Rio: Icons, Culture & Hidden Gems": "Most Popular",
    "Rio Express: Christ & Sugarloaf in 5 Hours": "Best for Cruise Passengers",
    "Island Escape: Ilha Grande by Private Speedboat": "Private Speedboat",
    "Your Rio, Your Way: Custom Private Tour": "Fully Customizable"
  },
  es: {
    "El Río Esencial: Íconos, Cultura y Joyas Ocultas": "Más Popular",
    "Río Express: Cristo y Pan de Azúcar en 5 Horas": "Ideal para Cruceristas",
    "Escape a la Isla: Ilha Grande en Lancha Privada": "Lancha Privada",
    "Tu Río, a Tu Manera: Tour Privado Personalizado": "Totalmente Personalizable"
  },
  "pt-br": {
    "O Essencial do Rio: Ícones, Cultura e Joias Escondidas": "Mais Popular",
    "Rio Express: Cristo e Pão de Açúcar em 5 Horas": "Ideal para Cruzeiros",
    "Escapada para a Ilha: Ilha Grande de Lancha Privativa": "Lancha Privada",
    "Seu Rio, do Seu Jeito: Passeio Privado Personalizado": "Totalmente Personalizável"
  }
};
---



<section class="featured-tours">
  <div class="container">
    <h2 class="section-title-decorated">{t("featuredTours.title")}</h2>
    <p class="section-subtitle">{t("featuredTours.subtitle")}</p>

    <div class="tours-grid grid grid-3">
      {featuredTours.map((tour) => (
        <TourCard
          tour={tour}
          lang={lang}
          badge={tourBadgeMap[lang]?.[tour.id]}
        />
      ))}
    </div>

    {/* QUICK FILTERS - TEMPORARIAMENTE DESATIVADO
    <nav class="quick-filters" aria-label={lang === "en" ? "Browse by category" : lang === "es" ? "Filtrar por categoría" : "Filtrar por categoria"}>
      {filters.map((f, i) => (
        <span class="qf-item">
          {i > 0 && <span class="qf-sep" aria-hidden="true">·</span>}
          <a href={f.href} class="qf-link">{f.label}</a>
        </span>
      ))}
    </nav>
    */}

    <div class="section-cta">
      <a
        href={toursBase}
        class="btn btn-outline-primary btn-lg"
      >
        {t("featuredTours.viewAll")}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .featured-tours {
    --section-subtitle-max: clamp(40rem, 75vw, 50rem);
    --cta-btn-gap: var(--space-xs);

    padding: var(--space-3xl) 0;
    background-color: var(--color-bg-alt);
  }

  .featured-tours .container {
    max-width: none;
    padding-inline: var(--space-xl-compact);
  }

  .section-subtitle {
    text-align: center;
    font-size: var(--font-size-h5);
    color: var(--color-text-light);
    line-height: var(--line-height-relaxed);
    max-width: var(--section-subtitle-max);
    margin: var(--space-md) auto var(--space-2xl);
  }

  .tours-grid {
    margin-bottom: var(--space-xl);
    gap: var(--space-md);
  }

  /* QUICK FILTERS - TEMPORARIAMENTE DESATIVADO
  .quick-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    margin-bottom: var(--space-xl);
  }

  .qf-item {
    display: flex;
    align-items: center;
  }

  .qf-sep {
    color: var(--color-border);
    padding: 0 var(--space-2xs);
    user-select: none;
  }

  .qf-link {
    font-size: var(--font-size-small);
    color: var(--color-text-light);
    text-decoration: none;
    padding: var(--space-2xs) var(--space-sm);
    border-radius: clamp(0.25rem, 0.5vw, 0.375rem);
    transition: color var(--transition-duration-slow) var(--transition-easing-default);
  }

  .qf-link:hover {
    color: var(--color-text);
    text-decoration: underline;
  }
  */

  .section-cta {
    text-align: center;
  }

  .section-cta .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--cta-btn-gap);
  }

  .featured-tours .section-cta .btn-outline-primary {
    border-color: transparent;
  }

  .featured-tours .section-cta .btn-outline-primary:focus,
  .featured-tours .section-cta .btn-outline-primary:focus-visible {
    outline: none;
    box-shadow: none;
  }

  
  @media (max-width: 768px) {
    .featured-tours {
      padding: var(--space-2xl) 0;
    }

    .section-title-decorated {
      text-align: center;
    }

    .section-subtitle {
      margin-bottom: var(--space-xl);
      font-size: var(--font-size-body);
      padding-inline: var(--space-md);
    }

    .tours-grid {
      margin-bottom: var(--space-xl);
    }
  }
</style>
