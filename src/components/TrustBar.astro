---



import { homeContent } from "../data/homeContent.js";

const { lang } = Astro.props;
const { items } = homeContent[lang].trustBar;


const icons = {
  star: '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>',
  reviews: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
  platforms: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>',
  calendar: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
};
---

<div class="trust-bar" role="list" aria-label="Trust signals">
  {items.map((item) => (
    <div class="trust-bar__item" role="listitem">
      <span class="trust-bar__icon" set:html={icons[item.icon] ?? ""} />
      <span class="trust-bar__text">{item.text}</span>
    </div>
  ))}
</div>

<style>
  .trust-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-xs) var(--space-xl);
    padding: var(--space-md) var(--space-xl-compact);
    background-color: var(--color-bg-alt);
    border-bottom: var(--border-width-hairline) solid var(--color-border-light);
    min-height: 64px;
  }

  .trust-bar__item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    white-space: nowrap;
  }

  .trust-bar__icon {
    display: flex;
    align-items: center;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .trust-bar__text {
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    letter-spacing: 0.01em;
  }

  @media (max-width: 600px) {
    .trust-bar {
      gap: var(--space-xs) var(--space-md);
      padding: var(--space-sm) var(--space-md);
      min-height: unset;
    }

    .trust-bar__item {
      flex-basis: calc(50% - var(--space-md));
      justify-content: center;
    }
  }
</style>
