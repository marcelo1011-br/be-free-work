---



import { homeContent } from "../data/homeContent.js";

const { lang } = Astro.props;
const content = homeContent[lang].faq;
---

<section class="faq">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{content.title}</h2>
      <p class="section-subtitle">{content.subtitle}</p>
    </div>

    <div class="faq-list">
      {
        content.questions.map((item) => (
          <article class="faq-item" data-faq-id={item.id} data-expanded="false">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">{item.question}</span>
              <span class="faq-icon" aria-hidden="true">
                <svg
                  width="24"
                  height="24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  viewBox="0 0 24 24"
                >
                  <line
                    class="faq-icon-horizontal"
                    x1="12"
                    y1="5"
                    x2="12"
                    y2="19"
                  />
                  <line
                    class="faq-icon-vertical"
                    x1="5"
                    y1="12"
                    x2="19"
                    y2="12"
                  />
                </svg>
              </span>
            </button>

            <div class="faq-answer">
              <p class="faq-answer-content">{item.answer}</p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="faq-whatsapp-cta">
      <p class="faq-whatsapp-text">
        {lang === "pt-br"
          ? "Ainda tem dúvidas? Fale diretamente com a nossa equipe."
          : lang === "es"
          ? "¿Aún tienes dudas? Habla directamente con nuestro equipo."
          : "Still have questions? Chat directly with our team."}
      </p>
      <a
        href="https://wa.me/5521979271637"
        class="btn btn-primary btn-lg faq-whatsapp-btn"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        {lang === "pt-br" ? "Falar no WhatsApp" : lang === "es" ? "Hablar por WhatsApp" : "Chat on WhatsApp"}
      </a>
    </div>
  </div>
</section>

<style>
  .faq {
    --faq-header-max: clamp(40rem, 75vw, 50rem);
    --faq-list-max: clamp(48rem, 80vw, 56.25rem);
    --faq-blur: var(--blur-md);
    --faq-border: var(--border-width-hairline);
    --faq-shadow-hover: 0 8px 24px color-mix(in srgb, black 25%, transparent);
    --faq-transition: var(--transition-duration-slow) var(--transition-easing-default);
    --faq-transition-fast: var(--transition-duration-normal) var(--transition-easing-default);
    --faq-hover-bg: color-mix(in srgb, white 5%, transparent);
    --faq-icon-size: clamp(1.25rem, 2.5vw, 1.5rem);
    --faq-focus-offset: calc(var(--focus-outline-width) * -1);

    padding: var(--space-3xl) 0;
    background-color: var(--color-bg-alt);
  }

  .section-header {
    text-align: center;
    max-width: var(--faq-header-max);
    margin: 0 auto var(--space-2xl);
  }

  .section-title {
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .section-subtitle {
    font-size: var(--font-size-h5);
    color: var(--color-text-light);
    line-height: var(--line-height-relaxed);
  }

  .faq-list {
    max-width: var(--faq-list-max);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .faq-item {
    background: var(--glass-bg);
    backdrop-filter: blur(var(--faq-blur));
    -webkit-backdrop-filter: blur(var(--faq-blur));
    border: var(--faq-border) solid var(--glass-border);
    border-radius: clamp(0.3rem, 0.6vw, 0.375rem);
    box-shadow: var(--glass-shadow);
    overflow: hidden;
    transition: box-shadow var(--faq-transition);
    display: grid;
    grid-template-rows: auto 0fr;
    transition: grid-template-rows var(--faq-transition);
  }

  .faq-item:hover {
    box-shadow: var(--faq-shadow-hover);
  }

  
  .faq-item[data-expanded="true"] {
    grid-template-rows: auto 1fr;
  }

  .faq-question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    transition: background-color var(--faq-transition-fast);
  }

  .faq-question:hover {
    background-color: var(--faq-hover-bg);
  }

  .faq-question:focus-visible {
    outline: var(--focus-outline-width) solid var(--color-accent);
    outline-offset: var(--faq-focus-offset);
  }

  .faq-question-text {
    font-size: var(--font-size-h5);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    line-height: var(--line-height-tight);
  }

  .faq-icon {
    flex-shrink: 0;
    width: var(--faq-icon-size);
    height: var(--faq-icon-size);
    color: var(--color-accent);
    transition: transform var(--faq-transition);
  }

  
  .faq-icon-horizontal {
    transition: transform var(--faq-transition);
  }

  .faq-question[aria-expanded="true"] .faq-icon-horizontal {
    transform: rotate(90deg);
    opacity: 0;
  }

  .faq-answer {
    overflow: hidden;
    transition: padding var(--faq-transition);
    padding: 0 var(--space-lg);
  }

  .faq-answer-content {
    color: var(--color-text-light);
    line-height: var(--line-height-relaxed);
    margin: 0;
  }

  
  .faq-item[data-expanded="true"] .faq-answer {
    padding: 0 var(--space-lg) var(--space-lg) var(--space-lg);
  }

  
  .faq-whatsapp-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-2xl);
    padding-top: var(--space-2xl);
    border-top: var(--faq-border) solid var(--glass-border);
    max-width: var(--faq-list-max);
    margin-inline: auto;
    text-align: center;
  }

  .faq-whatsapp-text {
    font-size: var(--font-size-h5);
    color: var(--color-text-light);
    margin: 0;
  }

  .faq-whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
  }

  @media (max-width: 768px) {
    .faq {
      padding: var(--space-2xl) 0;
    }

    .section-header {
      margin-bottom: var(--space-xl);
    }

    .faq-question {
      padding: var(--space-md);
    }

    .faq-question-text {
      font-size: var(--font-size-body);
    }

    .faq-answer {
      padding: 0 var(--space-md);
    }

    .faq-answer-content {
      font-size: var(--font-size-small);
    }

    .faq-item[data-expanded="true"] .faq-answer {
      padding: var(--space-md);
    }
  }
</style>

<script>
  

  
  const faqButtons = document.querySelectorAll(".faq-question");

  
  faqButtons.forEach((button) => {
    button.addEventListener("click", () => {
      
      const faqItem = button.closest(".faq-item") as HTMLElement;

      
      const isExpanded = button.getAttribute("aria-expanded") === "true";

      
      if (!isExpanded) {
        
        faqButtons.forEach((otherButton) => {
          const otherItem = otherButton.closest(".faq-item") as HTMLElement;
          otherButton.setAttribute("aria-expanded", "false");
          if (otherItem) otherItem.setAttribute("data-expanded", "false");
        });
      }

      
      if (isExpanded) {
        
        button.setAttribute("aria-expanded", "false");
        if (faqItem) faqItem.setAttribute("data-expanded", "false");
      } else {
        
        button.setAttribute("aria-expanded", "true");
        if (faqItem) faqItem.setAttribute("data-expanded", "true");
      }
    });
  });
</script>
