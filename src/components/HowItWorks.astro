---
import { homeContent } from "../data/homeContent.js";

const { lang } = Astro.props;
const content = (homeContent[lang] ?? homeContent.en).howItWorks;
---

<section class="how-it-works">
  <div class="container">
    <h2 class="section-title-decorated">{content.title}</h2>

    <div class="steps-grid">
      {content.steps.map((step, index) => (
        <div class="step-card">
          <div class="step-number">{index + 1}</div>
          <div class="step-content">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
          </div>
          {index < content.steps.length - 1 && (
            <div class="step-connector">
              <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="section-cta">
      <button type="button" class="btn btn-primary btn-lg" data-tour-select-trigger>
        {lang === "pt-br" ? "Reservar Meu Passeio" : lang === "es" ? "Reservar Mi Tour" : "Book My Tour"}
      </button>
    </div>
  </div>
</section>

<style>
  .how-it-works {
    --step-grid-min: 280px;
    --step-card-lift: -4px;
    --step-number-size: clamp(3rem, 6vw, 3.5rem);
    --step-number-border: var(--border-width-strong);
    --step-connector-offset: -32px;
    --step-icon-size: clamp(2rem, 4vw, 2.25rem);

    padding: var(--space-3xl) 0;
    background-color: var(--color-bg-white);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, var(--step-grid-min)), 1fr));
    gap: var(--space-md);
    margin-top: var(--space-2xl);
  }

  .step-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-xl);
    background: none;
    border: none;
    box-shadow: none;
    border-radius: clamp(0.3rem, 0.6vw, 0.375rem);
    transition: transform var(--transition-duration-slow) var(--transition-easing-default);
  }

  .step-card:hover {
    transform: translateY(var(--step-card-lift));
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--step-number-size);
    height: var(--step-number-size);
    border: var(--step-number-border) solid var(--color-border);
    border-radius: 50%;
    font-size: var(--font-size-h4);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .step-content {
    flex-grow: 1;
  }

  .step-title {
    font-size: var(--font-size-h5);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .step-description {
    font-size: var(--font-size-small);
    color: var(--color-text-light);
    line-height: var(--line-height-relaxed);
  }

  .step-connector {
    display: none;
    position: absolute;
    right: var(--step-connector-offset);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-border);
  }

  @media (min-width: 900px) {
    .step-connector {
      display: block;
    }
  }

  .section-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-2xl);
  }

  .section-cta .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .section-cta .btn-primary:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  @media (max-width: 768px) {
    .how-it-works {
      padding: var(--space-2xl) 0;
    }

    .section-title-decorated {
      text-align: center;
    }

    .steps-grid {
      margin-top: var(--space-lg);
      gap: var(--space-md);
    }

    .step-card {
      padding: var(--space-md);
      text-align: center;
      align-items: center;
    }

    .step-number {
      margin-bottom: var(--space-sm);
    }

    .step-title {
      font-size: var(--font-size-body);
    }

    .step-description {
      font-size: var(--font-size-small);
    }
  }
</style>
