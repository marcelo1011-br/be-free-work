---
import TourCard from "./TourCard.astro";
import { experiences } from "../data/experiences.js";
import { useTranslations } from "../i18n/utils";

const { lang } = Astro.props;
const t = useTranslations(lang);

const items = experiences[lang].slice(0, 3);
const experiencesBase = `/${lang}/${lang === "en" ? "experiences" : "experiencias"}`;
---

<section class="featured-experiences">
  <div class="container">
    <h2 class="section-title-decorated">{t("featuredExperiences.title")}</h2>
    <p class="section-subtitle">{t("featuredExperiences.subtitle")}</p>

    <div class="product-grid grid grid-3">
      {items.map((item) => (
        <TourCard item={item} lang={lang} section="experiences" />
      ))}
    </div>

    <div class="section-cta">
      <a href={experiencesBase} class="btn btn-outline-primary btn-lg">
        {t("featuredExperiences.viewAll")}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .featured-experiences {
    padding: var(--space-3xl) 0;
    background-color: var(--color-bg-white);
  }

  .featured-experiences .container {
    max-width: none;
    padding-inline: var(--space-xl-compact);
  }

  .section-subtitle {
    text-align: center;
    font-size: var(--font-size-h5);
    color: var(--color-text-light);
    line-height: var(--line-height-relaxed);
    max-width: clamp(40rem, 75vw, 50rem);
    margin: var(--space-md) auto var(--space-2xl);
  }

  .product-grid {
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .section-cta {
    display: flex;
    justify-content: center;
  }
</style>
